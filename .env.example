# =============================================================================
# Code Quality Gate - Environment Variables
# =============================================================================

# Application
APP_NAME=Code Quality Gate
DEBUG=false
LOG_LEVEL=info

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Analysis
QUALITY_THRESHOLD=6.0
MAX_FILE_SIZE_MB=10
ANALYZER_TIMEOUT_SECONDS=30

# File Handling
UPLOAD_DIR=/tmp/cqg_uploads
REPO_DIR=/tmp/cqg_repos
ALLOWED_EXTENSIONS=["*"]

# Optional AI Integrations
AI_INTEGRATIONS_ENABLED=true
AI_PROVIDERS=["openrouter"]
AI_REQUEST_TIMEOUT_SECONDS=20
AI_MAX_FILES=30
AI_MAX_CHARS_PER_FILE=20000
AI_CODERABBIT_API_URL=
AI_CODERABBIT_API_KEY=
AI_GREPTILE_API_URL=
AI_GREPTILE_API_KEY=
AI_OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
AI_OPENROUTER_API_KEY=
AI_OPENROUTER_MODEL=openai/gpt-oss-120b:free
AI_OPENROUTER_FREE_MODELS=["openai/gpt-oss-120b:free","arcee-ai/trinity-large-preview:free","z-ai/glm-4.5-air:free","stepfun/step-3.5-flash:free","nvidia/nemotron-3-nano-30b-a3b:free"]
AI_OPENROUTER_HTTP_REFERER=
AI_OPENROUTER_APP_TITLE=Code Quality Gate
