# =============================================================================
# Code Quality Gate - Environment Variables
# =============================================================================

# Application
APP_NAME=Code Quality Gate
DEBUG=false
LOG_LEVEL=info

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Analysis
QUALITY_THRESHOLD=6.0
MAX_FILE_SIZE_MB=10
ANALYZER_TIMEOUT_SECONDS=30

# File Handling
UPLOAD_DIR=/tmp/cqg_uploads
REPO_DIR=/tmp/cqg_repos
ALLOWED_EXTENSIONS=[".py"]
